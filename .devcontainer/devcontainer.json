{
    "build": {
      "dockerfile": "Dockerfile",
      "context": "."
    },
    "containerEnv": {
      "HOME": "/home/vscode"
    },
    "customizations": {
      "vscode": {
        "extensions": [
          "ms-python.python",
          "ms-toolsai.jupyter",
          "ms-python.vscode-pylance",
          "redhat.vscode-yaml",
          "mhutchie.git-graph",
          "ms-azuretools.vscode-docker",
          "njpwerner.autodocstring",
          "tamasfe.even-better-toml",
          "saoudrizwan.claude-dev",
          "TendouAlice.markdown-obsidian-callout",
          "bierner.markdown-mermaid",
          "HashiCorp.HCL",
          "kokakiwi.vscode-just",
          "cweijan.vscode-postgresql-client2"
        ],
        "settings": {
          "python.pythonPath": "/home/vscode/workspace/.venv/bin/python"
        }
      }
    },
    "postCreateCommand": "chmod +x ${containerWorkspaceFolder}/.devcontainer/bootstrap.sh && ${containerWorkspaceFolder}/.devcontainer/bootstrap.sh",
    "postStartCommand": "git config --global --add safe.directory ${containerWorkspaceFolder} && git config --global --add credential.useHttpPath true",
    "runArgs": [
      "--env-file",
      ".devcontainer/.env"
    ],
    "workspaceFolder": "/home/vscode/workspace",
    "workspaceMount": "source=${localWorkspaceFolder},target=/home/vscode/workspace,type=bind",
    "features": {
      "ghcr.io/devcontainers/features/docker-in-docker:2": {}
    },
    "mounts": [
      "type=bind,source=${localWorkspaceFolder}/.devcontainer/daemon.json,target=/etc/docker/daemon.json,consistency=cached"
    ]
}
