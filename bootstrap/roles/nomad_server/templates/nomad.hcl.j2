# Full configuration options can be found at https://developer.hashicorp.com/nomad/docs/configuration

datacenter = "localstack"
data_dir  = "/opt/nomad/data"
plugin_dir = "/usr/bin"
bind_addr = "0.0.0.0"

server {
  enabled          = true
  bootstrap_expect = 1
}

acl {
  enabled = true
}

client {
  enabled = true

  options = {
    "driver.denylist" = "docker"
  }
}

consul {
  address = "{{ nomad_server_ip_address }}:8500"
  token   = "{{ nomad_server_consul_token_secret }}"
}

vault {
  enabled = true
  address = "http://{{ nomad_server_ip_address }}:8200"

  tls_skip_verify = true
  default_identity {
    aud = ["vault.io"]
    ttl = "1h"
  }
}

plugin "nomad-driver-podman" {
  config {
    volumes {
       enabled = true
       selinuxlabel = "z"
    }
  }
}

plugin "raw_exec" {
  config {
    enabled = true
  }
}
