{
  "uid": "localstack-overview",
  "title": "Localstack Cluster Overview",
  "tags": ["localstack"],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "time": {"from": "now-1h", "to": "now"},
  "refresh": "30s",
  "timepicker": {},
  "templating": {"list": []},
  "annotations": {"list": []},
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Nodes Up",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "count(up{job=\"node\",instance!~\".+:.+\"} == 1)", "refId": "A"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "max": 5,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 4},
              {"color": "green", "value": 5}
            ]
          },
          "color": {"mode": "thresholds"}
        }
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": ""},
        "graphMode": "none",
        "textMode": "auto",
        "colorMode": "background"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Avg CPU %",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "avg(100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100))", "refId": "A"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 60},
              {"color": "red", "value": 85}
            ]
          },
          "color": {"mode": "thresholds"}
        }
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "graphMode": "area",
        "colorMode": "value"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Avg Memory %",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "avg(100 * (1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)))", "refId": "A"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 70},
              {"color": "red", "value": 90}
            ]
          },
          "color": {"mode": "thresholds"}
        }
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "graphMode": "area",
        "colorMode": "value"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Memex errors (1h)",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [
        {"expr": "sum(count_over_time({task=\"memex\"} |~ \"(?i)error|exception|traceback\" [1h]))", "refId": "A"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 10}
            ]
          },
          "color": {"mode": "thresholds"}
        }
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "graphMode": "none",
        "colorMode": "background"
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "CPU per node",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "100 - (avg by (node) (rate(node_cpu_seconds_total{mode=\"idle\"}[1m])) * 100)", "legendFormat": "{{node}}", "refId": "A"}
      ],
      "fieldConfig": {
        "defaults": {"unit": "percent", "min": 0, "max": 100, "custom": {"lineWidth": 1, "fillOpacity": 10}}
      },
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Memory used per node",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes", "legendFormat": "{{node}}", "refId": "A"}
      ],
      "fieldConfig": {
        "defaults": {"unit": "bytes", "custom": {"lineWidth": 1, "fillOpacity": 10}}
      },
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Node uptime",
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 12},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "time() - node_boot_time_seconds", "legendFormat": "{{node}}", "refId": "A"}
      ],
      "fieldConfig": {
        "defaults": {"unit": "s", "custom": {"lineWidth": 1, "fillOpacity": 5}}
      },
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}}
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Log volume by task (per minute)",
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 12},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [
        {"expr": "sum by (task) (rate({job=\"nomad\"}[1m]))", "legendFormat": "{{task}}", "refId": "A"}
      ],
      "fieldConfig": {
        "defaults": {"unit": "short", "custom": {"lineWidth": 1, "fillOpacity": 10, "drawStyle": "bars"}}
      },
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}}
    },
    {
      "id": 9,
      "type": "logs",
      "title": "Memex tail",
      "gridPos": {"h": 12, "w": 24, "x": 0, "y": 18},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [
        {"expr": "{task=\"memex\"}", "refId": "A"}
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      }
    }
  ]
}
