{
  "uid": "localstack-ingress",
  "title": "Ingress (HAProxy + Consul)",
  "tags": ["localstack", "haproxy", "consul"],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "time": {"from": "now-1h", "to": "now"},
  "refresh": "30s",
  "timepicker": {},
  "annotations": {"list": []},
  "templating": {
    "list": [
      {
        "name": "frontend",
        "label": "Frontend",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "query": "label_values(haproxy_frontend_current_sessions, proxy)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "allValue": ".+"
      },
      {
        "name": "backend",
        "label": "Backend",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "query": "label_values(haproxy_backend_current_sessions, proxy)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "allValue": ".+"
      }
    ]
  },
  "links": [
    {"title": "Cluster Overview", "url": "/d/localstack-overview/?${__url_time_range}", "type": "link", "icon": "external link", "targetBlank": false}
  ],
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "HAProxy",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "collapsed": false,
      "panels": []
    },
    {
      "id": 2,
      "type": "stat",
      "title": "HAProxy up",
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 1},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "up{job=\"haproxy\"}", "refId": "A"}],
      "fieldConfig": {
        "defaults": {
          "mappings": [{"type": "value", "options": {"0": {"text": "DOWN", "color": "red"}, "1": {"text": "UP", "color": "green"}}}],
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "graphMode": "none", "colorMode": "background"}
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Total req/s",
      "gridPos": {"h": 4, "w": 5, "x": 4, "y": 1},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(rate(haproxy_frontend_http_requests_total[1m]))", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "reqps"}},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "graphMode": "area", "colorMode": "value"}
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Active sessions",
      "gridPos": {"h": 4, "w": 5, "x": 9, "y": 1},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(haproxy_frontend_current_sessions)", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short"}},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "graphMode": "area", "colorMode": "value"}
    },
    {
      "id": 5,
      "type": "stat",
      "title": "5xx rate",
      "gridPos": {"h": 4, "w": 5, "x": 14, "y": 1},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(rate(haproxy_backend_http_responses_total{code=\"5xx\"}[1m]))", "refId": "A"}],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 0.1}, {"color": "red", "value": 1}]},
          "color": {"mode": "thresholds"}
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "graphMode": "area", "colorMode": "value"}
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Backends down",
      "gridPos": {"h": 4, "w": 5, "x": 19, "y": 1},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(haproxy_backend_status == 0)", "refId": "A"}],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]},
          "color": {"mode": "thresholds"}
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "graphMode": "none", "colorMode": "background"}
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "HTTP responses by class",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 5},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "sum by (code) (rate(haproxy_frontend_http_responses_total{proxy=~\"$frontend\"}[1m]))", "legendFormat": "{{code}}", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "ops", "custom": {"lineWidth": 1, "fillOpacity": 30, "stacking": {"mode": "normal"}}}},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}}
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "5xx rate per backend",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 5},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "sum by (proxy) (rate(haproxy_backend_http_responses_total{code=\"5xx\",proxy=~\"$backend\"}[1m]))", "legendFormat": "{{proxy}}", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "ops", "custom": {"lineWidth": 1, "fillOpacity": 10}}},
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "max"]}}
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Frontend sessions",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 13},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "haproxy_frontend_current_sessions{proxy=~\"$frontend\"}", "legendFormat": "{{proxy}}", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "short", "custom": {"lineWidth": 1, "fillOpacity": 10}}},
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "max"]}}
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Frontend bytes in/out",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 13},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "sum by (proxy) (rate(haproxy_frontend_bytes_in_total{proxy=~\"$frontend\"}[1m]))", "legendFormat": "in {{proxy}}", "refId": "A"},
        {"expr": "-sum by (proxy) (rate(haproxy_frontend_bytes_out_total{proxy=~\"$frontend\"}[1m]))", "legendFormat": "out {{proxy}}", "refId": "B"}
      ],
      "fieldConfig": {"defaults": {"unit": "Bps", "custom": {"lineWidth": 1, "fillOpacity": 10}}},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}}
    },
    {
      "id": 11,
      "type": "table",
      "title": "Backend status",
      "gridPos": {"h": 9, "w": 24, "x": 0, "y": 21},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "haproxy_backend_status{proxy=~\"$backend\"}", "refId": "A", "instant": true, "format": "table"}
      ],
      "transformations": [
        {"id": "organize", "options": {"excludeByName": {"Time": true, "__name__": true, "instance": true, "job": true}, "renameByName": {"proxy": "Backend", "Value": "Status"}}}
      ],
      "fieldConfig": {
        "defaults": {"custom": {"align": "left"}, "mappings": [{"type": "value", "options": {"0": {"text": "DOWN", "color": "red"}, "1": {"text": "UP", "color": "green"}}}]},
        "overrides": [
          {"matcher": {"id": "byName", "options": "Status"}, "properties": [
            {"id": "custom.cellOptions", "value": {"type": "color-background", "mode": "basic"}},
            {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}}
          ]}
        ]
      }
    },
    {
      "id": 12,
      "type": "row",
      "title": "Consul",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 30},
      "collapsed": false,
      "panels": []
    },
    {
      "id": 13,
      "type": "stat",
      "title": "Consul up",
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 31},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "up{job=\"consul\"}", "refId": "A"}],
      "fieldConfig": {
        "defaults": {
          "mappings": [{"type": "value", "options": {"0": {"text": "DOWN", "color": "red"}, "1": {"text": "UP", "color": "green"}}}],
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "graphMode": "none", "colorMode": "background"}
    },
    {
      "id": 14,
      "type": "stat",
      "title": "Catalog services",
      "gridPos": {"h": 4, "w": 5, "x": 4, "y": 31},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "consul_catalog_services", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short"}},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "graphMode": "area", "colorMode": "value"}
    },
    {
      "id": 15,
      "type": "stat",
      "title": "Raft peers",
      "gridPos": {"h": 4, "w": 5, "x": 9, "y": 31},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "consul_raft_peers", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short"}},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "graphMode": "none", "colorMode": "value"}
    },
    {
      "id": 16,
      "type": "stat",
      "title": "Failing checks",
      "gridPos": {"h": 4, "w": 5, "x": 14, "y": 31},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(consul_health_node_status{status=\"critical\"} or vector(0))", "refId": "A"}],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}, {"color": "red", "value": 5}]},
          "color": {"mode": "thresholds"}
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "graphMode": "none", "colorMode": "background"}
    },
    {
      "id": 17,
      "type": "stat",
      "title": "KV ops/s",
      "gridPos": {"h": 4, "w": 5, "x": 19, "y": 31},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "rate(consul_kvs_apply_count[5m])", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "ops"}},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "graphMode": "area", "colorMode": "value"}
    },
    {
      "id": 18,
      "type": "timeseries",
      "title": "Catalog service nodes by status",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 35},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "sum by (status) (consul_catalog_service_node_healthy)", "legendFormat": "{{status}}", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "short", "custom": {"lineWidth": 1, "fillOpacity": 10, "stacking": {"mode": "normal"}}}},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}}
    },
    {
      "id": 19,
      "type": "timeseries",
      "title": "Consul RPC rate",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 35},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "rate(consul_rpc_request[1m])", "legendFormat": "request", "refId": "A"},
        {"expr": "rate(consul_rpc_query[1m])", "legendFormat": "query", "refId": "B"}
      ],
      "fieldConfig": {"defaults": {"unit": "ops", "custom": {"lineWidth": 1, "fillOpacity": 10}}},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}}
    },
    {
      "id": 20,
      "type": "logs",
      "title": "HAProxy / Consul logs",
      "gridPos": {"h": 12, "w": 24, "x": 0, "y": 43},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [{"expr": "{job=\"journald\", unit=~\"haproxy.*|consul.*\"} or {job=\"nomad\", task=~\"haproxy.*|consul.*\"}", "refId": "A"}],
      "options": {"showTime": true, "showLabels": true, "wrapLogMessage": true, "enableLogDetails": true, "dedupStrategy": "none", "sortOrder": "Descending"}
    }
  ]
}
