{
  "uid": "localstack-minio",
  "title": "MinIO",
  "tags": ["localstack", "minio"],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "time": {"from": "now-1h", "to": "now"},
  "refresh": "30s",
  "timepicker": {},
  "annotations": {"list": []},
  "templating": {
    "list": [
      {
        "name": "bucket",
        "label": "Bucket",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "query": "label_values(minio_bucket_usage_total_bytes, bucket)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "allValue": ".+"
      }
    ]
  },
  "links": [
    {"title": "Cluster Overview", "url": "/d/localstack-overview/?${__url_time_range}", "type": "link", "icon": "external link", "targetBlank": false}
  ],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Nodes online",
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "minio_cluster_nodes_online_total", "refId": "A"}],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]},
          "color": {"mode": "thresholds"}
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "graphMode": "none", "colorMode": "background"}
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Nodes offline",
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "minio_cluster_nodes_offline_total", "refId": "A"}],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]},
          "color": {"mode": "thresholds"}
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "graphMode": "none", "colorMode": "background"}
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Drives online",
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "minio_cluster_drive_online_total", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short"}},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "graphMode": "none", "colorMode": "value"}
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Drives offline",
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "minio_cluster_drive_offline_total", "refId": "A"}],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]},
          "color": {"mode": "thresholds"}
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "graphMode": "none", "colorMode": "background"}
    },
    {
      "id": 5,
      "type": "gauge",
      "title": "Cluster capacity used",
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "100 * (1 - minio_cluster_capacity_usable_free_bytes / minio_cluster_capacity_usable_total_bytes)", "refId": "A"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 70}, {"color": "red", "value": 90}]}
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "showThresholdMarkers": true}
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Total objects",
      "gridPos": {"h": 4, "w": 4, "x": 20, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "minio_cluster_usage_object_total", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short"}},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "graphMode": "area", "colorMode": "value"}
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Usable capacity (used vs free)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "minio_cluster_capacity_usable_total_bytes - minio_cluster_capacity_usable_free_bytes", "legendFormat": "used", "refId": "A"},
        {"expr": "minio_cluster_capacity_usable_free_bytes", "legendFormat": "free", "refId": "B"}
      ],
      "fieldConfig": {"defaults": {"unit": "bytes", "custom": {"lineWidth": 1, "fillOpacity": 30, "stacking": {"mode": "normal"}}}},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}}
    },
    {
      "id": 8,
      "type": "bargauge",
      "title": "Top 10 buckets by size",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "topk(10, minio_bucket_usage_total_bytes{bucket=~\"$bucket\"})", "legendFormat": "{{bucket}}", "refId": "A", "instant": true}
      ],
      "fieldConfig": {"defaults": {"unit": "bytes", "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}},
      "options": {"orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true}
    },
    {
      "id": 9,
      "type": "table",
      "title": "Bucket details",
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 12},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "minio_bucket_usage_total_bytes{bucket=~\"$bucket\"}", "refId": "A", "instant": true, "format": "table"},
        {"expr": "minio_bucket_usage_object_total{bucket=~\"$bucket\"}", "refId": "B", "instant": true, "format": "table"}
      ],
      "transformations": [
        {"id": "joinByField", "options": {"byField": "bucket", "mode": "outer"}},
        {"id": "organize", "options": {"excludeByName": {"Time 1": true, "Time 2": true, "instance 1": true, "instance 2": true, "job 1": true, "job 2": true, "__name__ 1": true, "__name__ 2": true, "server 1": true, "server 2": true}, "renameByName": {"bucket": "Bucket", "Value #A": "Size", "Value #B": "Objects"}}}
      ],
      "fieldConfig": {
        "defaults": {"custom": {"align": "left"}},
        "overrides": [
          {"matcher": {"id": "byName", "options": "Size"}, "properties": [{"id": "unit", "value": "bytes"}]},
          {"matcher": {"id": "byName", "options": "Objects"}, "properties": [{"id": "unit", "value": "short"}]}
        ]
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "S3 request rate by API",
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 12},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "sum by (api) (rate(minio_s3_requests_total[1m]))", "legendFormat": "{{api}}", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "ops", "custom": {"lineWidth": 1, "fillOpacity": 10}}},
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "max"]}}
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "S3 errors",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 21},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "sum(rate(minio_s3_requests_errors_total[1m]))", "legendFormat": "errors", "refId": "A"},
        {"expr": "sum(rate(minio_s3_requests_4xx_errors_total[1m]))", "legendFormat": "4xx", "refId": "B"},
        {"expr": "sum(rate(minio_s3_requests_5xx_errors_total[1m]))", "legendFormat": "5xx", "refId": "C"}
      ],
      "fieldConfig": {
        "defaults": {"unit": "ops", "custom": {"lineWidth": 1, "fillOpacity": 10}}
      },
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}}
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "S3 traffic",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 21},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "rate(minio_s3_traffic_received_bytes[1m])", "legendFormat": "received", "refId": "A"},
        {"expr": "-rate(minio_s3_traffic_sent_bytes[1m])", "legendFormat": "sent", "refId": "B"}
      ],
      "fieldConfig": {"defaults": {"unit": "Bps", "custom": {"lineWidth": 1, "fillOpacity": 10}}},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}}
    },
    {
      "id": 13,
      "type": "logs",
      "title": "MinIO logs",
      "gridPos": {"h": 12, "w": 24, "x": 0, "y": 29},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [{"expr": "{job=\"nomad\", task=~\"minio.*\"}", "refId": "A"}],
      "options": {"showTime": true, "showLabels": false, "wrapLogMessage": true, "enableLogDetails": true, "dedupStrategy": "none", "sortOrder": "Descending"}
    }
  ]
}
