{
  "uid": "localstack-nats",
  "title": "NATS / JetStream",
  "tags": ["localstack", "nats"],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "time": {"from": "now-1h", "to": "now"},
  "refresh": "30s",
  "timepicker": {},
  "annotations": {"list": []},
  "templating": {
    "list": [
      {
        "name": "stream",
        "label": "JetStream stream",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "query": "label_values(jetstream_stream_total_messages, stream_name)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "allValue": ".+"
      }
    ]
  },
  "links": [
    {"title": "Cluster Overview", "url": "/d/localstack-overview/?${__url_time_range}", "type": "link", "icon": "external link", "targetBlank": false}
  ],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Server up",
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "up{job=\"nats-exporter\"}", "refId": "A"}],
      "fieldConfig": {
        "defaults": {
          "mappings": [{"type": "value", "options": {"0": {"text": "DOWN", "color": "red"}, "1": {"text": "UP", "color": "green"}}}],
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "graphMode": "none", "colorMode": "background"}
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Connections",
      "gridPos": {"h": 4, "w": 5, "x": 4, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "gnatsd_varz_connections", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short"}},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "graphMode": "area", "colorMode": "value"}
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Subscriptions",
      "gridPos": {"h": 4, "w": 5, "x": 9, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "gnatsd_varz_subscriptions", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short"}},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "graphMode": "area", "colorMode": "value"}
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Slow consumers",
      "gridPos": {"h": 4, "w": 5, "x": 14, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "gnatsd_varz_slow_consumers", "refId": "A"}],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]},
          "color": {"mode": "thresholds"}
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "graphMode": "none", "colorMode": "background"}
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Uptime",
      "gridPos": {"h": 4, "w": 5, "x": 19, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "gnatsd_varz_uptime_seconds", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "s"}},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "graphMode": "none", "colorMode": "value"}
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Messages per second",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "rate(gnatsd_varz_in_msgs[1m])", "legendFormat": "in", "refId": "A"},
        {"expr": "rate(gnatsd_varz_out_msgs[1m])", "legendFormat": "out", "refId": "B"}
      ],
      "fieldConfig": {"defaults": {"unit": "ops", "custom": {"lineWidth": 1, "fillOpacity": 10}}},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}}
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Bytes per second",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "rate(gnatsd_varz_in_bytes[1m])", "legendFormat": "in", "refId": "A"},
        {"expr": "-rate(gnatsd_varz_out_bytes[1m])", "legendFormat": "out", "refId": "B"}
      ],
      "fieldConfig": {"defaults": {"unit": "Bps", "custom": {"lineWidth": 1, "fillOpacity": 10}}},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}}
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Connections over time",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "gnatsd_varz_connections", "legendFormat": "current", "refId": "A"},
        {"expr": "gnatsd_varz_total_connections", "legendFormat": "total (cumulative)", "refId": "B"}
      ],
      "fieldConfig": {"defaults": {"unit": "short", "custom": {"lineWidth": 1, "fillOpacity": 10}}},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}}
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Resource usage (memory / cpu)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "gnatsd_varz_mem", "legendFormat": "mem", "refId": "A"},
        {"expr": "gnatsd_varz_cpu", "legendFormat": "cpu %", "refId": "B"}
      ],
      "fieldConfig": {
        "defaults": {"custom": {"lineWidth": 1, "fillOpacity": 10}},
        "overrides": [
          {"matcher": {"id": "byName", "options": "mem"}, "properties": [{"id": "unit", "value": "bytes"}]},
          {"matcher": {"id": "byName", "options": "cpu %"}, "properties": [{"id": "unit", "value": "percent"}]}
        ]
      },
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}}
    },
    {
      "id": 10,
      "type": "table",
      "title": "JetStream streams",
      "gridPos": {"h": 9, "w": 24, "x": 0, "y": 20},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "jetstream_stream_total_messages{stream_name=~\"$stream\"}", "refId": "A", "instant": true, "format": "table"},
        {"expr": "jetstream_stream_total_bytes{stream_name=~\"$stream\"}", "refId": "B", "instant": true, "format": "table"},
        {"expr": "jetstream_stream_first_seq{stream_name=~\"$stream\"}", "refId": "C", "instant": true, "format": "table"},
        {"expr": "jetstream_stream_last_seq{stream_name=~\"$stream\"}", "refId": "D", "instant": true, "format": "table"},
        {"expr": "jetstream_stream_consumer_count{stream_name=~\"$stream\"}", "refId": "E", "instant": true, "format": "table"}
      ],
      "transformations": [
        {"id": "joinByField", "options": {"byField": "stream_name", "mode": "outer"}},
        {"id": "organize", "options": {
          "excludeByName": {"Time 1": true, "Time 2": true, "Time 3": true, "Time 4": true, "Time 5": true, "instance 1": true, "instance 2": true, "instance 3": true, "instance 4": true, "instance 5": true, "job 1": true, "job 2": true, "job 3": true, "job 4": true, "job 5": true, "__name__ 1": true, "__name__ 2": true, "__name__ 3": true, "__name__ 4": true, "__name__ 5": true, "account 1": true, "account 2": true, "account 3": true, "account 4": true, "account 5": true},
          "renameByName": {"stream_name": "Stream", "Value #A": "Messages", "Value #B": "Bytes", "Value #C": "First seq", "Value #D": "Last seq", "Value #E": "Consumers"}
        }}
      ],
      "fieldConfig": {
        "defaults": {"custom": {"align": "left"}},
        "overrides": [
          {"matcher": {"id": "byName", "options": "Bytes"}, "properties": [{"id": "unit", "value": "bytes"}]}
        ]
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "JetStream consumer pending",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 29},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "jetstream_consumer_num_pending{stream_name=~\"$stream\"}", "legendFormat": "{{stream_name}}/{{consumer_name}}", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "short", "custom": {"lineWidth": 1, "fillOpacity": 10}}},
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "max"]}}
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "JetStream redelivered",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 29},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "rate(jetstream_consumer_num_redelivered{stream_name=~\"$stream\"}[5m])", "legendFormat": "{{stream_name}}/{{consumer_name}}", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "ops", "custom": {"lineWidth": 1, "fillOpacity": 10}}},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}}
    },
    {
      "id": 13,
      "type": "logs",
      "title": "NATS logs",
      "gridPos": {"h": 12, "w": 24, "x": 0, "y": 37},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [{"expr": "{job=\"nomad\", task=~\"nats.*\"}", "refId": "A"}],
      "options": {"showTime": true, "showLabels": true, "wrapLogMessage": true, "enableLogDetails": true, "dedupStrategy": "none", "sortOrder": "Descending"}
    }
  ]
}
