{
  "uid": "localstack-postgres",
  "title": "PostgreSQL",
  "tags": ["localstack", "postgres"],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "time": {"from": "now-1h", "to": "now"},
  "refresh": "30s",
  "timepicker": {},
  "annotations": {"list": []},
  "templating": {
    "list": [
      {
        "name": "datname",
        "label": "Database",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "query": "label_values(pg_database_size_bytes, datname)",
        "regex": "/^(?!template).+/",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "allValue": ".+"
      },
      {
        "name": "state",
        "label": "Connection state",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "query": "label_values(pg_stat_activity_count, state)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "allValue": ".+"
      }
    ]
  },
  "links": [
    {"title": "Cluster Overview", "url": "/d/localstack-overview/?${__url_time_range}", "type": "link", "icon": "external link", "targetBlank": false}
  ],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "pg_up",
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "pg_up", "refId": "A"}],
      "fieldConfig": {
        "defaults": {
          "mappings": [{"type": "value", "options": {"0": {"text": "DOWN", "color": "red"}, "1": {"text": "UP", "color": "green"}}}],
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "graphMode": "none", "colorMode": "background"}
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Uptime",
      "gridPos": {"h": 4, "w": 5, "x": 4, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "time() - pg_postmaster_start_time_seconds", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "s"}},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "graphMode": "none", "colorMode": "value"}
    },
    {
      "id": 3,
      "type": "gauge",
      "title": "Connections used",
      "gridPos": {"h": 4, "w": 5, "x": 9, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "100 * sum(pg_stat_activity_count) / max(pg_settings_max_connections)", "refId": "A"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 70}, {"color": "red", "value": 90}]}
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "showThresholdLabels": false, "showThresholdMarkers": true}
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Cache hit ratio (5m)",
      "gridPos": {"h": 4, "w": 5, "x": 14, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "100 * sum(rate(pg_stat_database_blks_hit{datname=~\"$datname\"}[5m])) / (sum(rate(pg_stat_database_blks_hit{datname=~\"$datname\"}[5m])) + sum(rate(pg_stat_database_blks_read{datname=~\"$datname\"}[5m])))", "refId": "A"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 90}, {"color": "green", "value": 95}]},
          "color": {"mode": "thresholds"}
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "graphMode": "area", "colorMode": "value"}
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Deadlocks (1h)",
      "gridPos": {"h": 4, "w": 5, "x": 19, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(increase(pg_stat_database_deadlocks{datname=~\"$datname\"}[1h]))", "refId": "A"}],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}, {"color": "red", "value": 10}]},
          "color": {"mode": "thresholds"}
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "graphMode": "none", "colorMode": "background"}
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Connections by state",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "sum by (state) (pg_stat_activity_count{state=~\"$state\"})", "legendFormat": "{{state}}", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "short", "custom": {"lineWidth": 1, "fillOpacity": 10, "stacking": {"mode": "normal"}}}},
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "max"]}}
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Transactions per second",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "sum by (datname) (rate(pg_stat_database_xact_commit{datname=~\"$datname\"}[1m]))", "legendFormat": "commit {{datname}}", "refId": "A"},
        {"expr": "sum by (datname) (rate(pg_stat_database_xact_rollback{datname=~\"$datname\"}[1m]))", "legendFormat": "rollback {{datname}}", "refId": "B"}
      ],
      "fieldConfig": {"defaults": {"unit": "ops", "custom": {"lineWidth": 1, "fillOpacity": 10}}},
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "max"]}}
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Tuple ops",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "sum(rate(pg_stat_database_tup_returned{datname=~\"$datname\"}[1m]))", "legendFormat": "returned", "refId": "A"},
        {"expr": "sum(rate(pg_stat_database_tup_fetched{datname=~\"$datname\"}[1m]))", "legendFormat": "fetched", "refId": "B"},
        {"expr": "sum(rate(pg_stat_database_tup_inserted{datname=~\"$datname\"}[1m]))", "legendFormat": "inserted", "refId": "C"},
        {"expr": "sum(rate(pg_stat_database_tup_updated{datname=~\"$datname\"}[1m]))", "legendFormat": "updated", "refId": "D"},
        {"expr": "sum(rate(pg_stat_database_tup_deleted{datname=~\"$datname\"}[1m]))", "legendFormat": "deleted", "refId": "E"}
      ],
      "fieldConfig": {"defaults": {"unit": "ops", "custom": {"lineWidth": 1, "fillOpacity": 5}}},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}}
    },
    {
      "id": 9,
      "type": "bargauge",
      "title": "Database size",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "pg_database_size_bytes{datname=~\"$datname\"}", "legendFormat": "{{datname}}", "refId": "A", "instant": true}
      ],
      "fieldConfig": {"defaults": {"unit": "bytes", "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}},
      "options": {"orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true}
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Block I/O",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "sum(rate(pg_stat_database_blks_hit{datname=~\"$datname\"}[1m]))", "legendFormat": "hit", "refId": "A"},
        {"expr": "sum(rate(pg_stat_database_blks_read{datname=~\"$datname\"}[1m]))", "legendFormat": "read (disk)", "refId": "B"}
      ],
      "fieldConfig": {"defaults": {"unit": "ops", "custom": {"lineWidth": 1, "fillOpacity": 10}}},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}}
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Replication lag",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "pg_stat_replication_pg_wal_lsn_diff", "legendFormat": "{{client_addr}}", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "bytes", "custom": {"lineWidth": 1, "fillOpacity": 10}}},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}}
    },
    {
      "id": 12,
      "type": "table",
      "title": "Long-running queries (top 10)",
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 28},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "topk(10, pg_stat_activity_max_tx_duration{datname=~\"$datname\"})", "refId": "A", "instant": true, "format": "table"}
      ],
      "transformations": [
        {"id": "organize", "options": {"excludeByName": {"Time": true, "__name__": true, "instance": true, "job": true}, "renameByName": {"datname": "Database", "state": "State", "Value": "Max tx duration (s)"}}}
      ],
      "fieldConfig": {
        "defaults": {"custom": {"align": "left"}},
        "overrides": [
          {"matcher": {"id": "byName", "options": "Max tx duration (s)"}, "properties": [
            {"id": "unit", "value": "s"},
            {"id": "custom.cellOptions", "value": {"type": "color-background", "mode": "basic"}},
            {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 30}, {"color": "red", "value": 300}]}}
          ]}
        ]
      }
    },
    {
      "id": 13,
      "type": "stat",
      "title": "Conflicts (1h)",
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 28},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "sum(increase(pg_stat_database_conflicts{datname=~\"$datname\"}[1h]))", "refId": "A"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}, {"color": "red", "value": 10}]},
          "color": {"mode": "thresholds"}
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "graphMode": "area", "colorMode": "value"}
    },
    {
      "id": 14,
      "type": "logs",
      "title": "PostgreSQL logs",
      "gridPos": {"h": 12, "w": 24, "x": 0, "y": 37},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [{"expr": "{job=\"nomad\", task=~\"postgres.*\"}", "refId": "A"}],
      "options": {"showTime": true, "showLabels": false, "wrapLogMessage": true, "enableLogDetails": true, "dedupStrategy": "none", "sortOrder": "Descending"}
    }
  ]
}
